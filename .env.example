# Sreshta Nutri Mithai - Environment Configuration

# Server Port
PORT=5000

# Supabase Credentials
# Find these in Supabase Dashboard under Project Settings -> API
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Brevo (Sendinblue) Configuration for Transactional Emails
# Find this in Brevo under SMTP & API Keys -> Generate Key
BREVO_API_KEY=xkeysib-your-generated-api-v3-key
BREVO_SENDER_EMAIL=orders@yourdomain.com
BREVO_SENDER_NAME="Sreshta Nutri Mithai"

# Admin Authentication Password
# Change this to a secure password for admin dashboard logins
ADMIN_PASSWORD=SreshtaAdmin2026

# Razorpay Credentials
# Find these in Razorpay Dashboard under Settings -> API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
